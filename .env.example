# Firebase 환경변수 예시 파일
# 이 파일을 복사하여 .env 라는 이름으로 저장하고 아래 값들을 채워넣으세요.
# cp .env.example .env

VITE_FIREBASE_API_KEY="여기에_Firebase_API_KEY_입력"
VITE_FIREBASE_AUTH_DOMAIN="여기에_프로젝트ID.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://여기에_프로젝트ID-default-rtdb.asia-southeast1.firebasedatabase.app/"
VITE_FIREBASE_PROJECT_ID="여기에_프로젝트ID"
VITE_FIREBASE_STORAGE_BUCKET="여기에_프로젝트ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="여기에_SENDER_ID"
VITE_FIREBASE_APP_ID="1:여기에_SENDER_ID:web:여기에_APP_ID"
